m":"linux","tags":["audit","linux","kernel"]},{"event_id":"1200","event_name":"AUDIT_DAEMON_START","description":"Daemon startup record","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1201","event_name":"AUDIT_DAEMON_END","description":"Daemon normal stop record","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1202","event_name":"AUDIT_DAEMON_ABORT","description":"Daemon error stop record","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1203","event_name":"AUDIT_DAEMON_CONFIG","description":"Daemon config change","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1300","event_name":"AUDIT_SYSCALL","description":"Syscall event - records syscall number, arguments, success/fail, uid, gid, pid. Foundation of auditd monitoring. Configure audit rules with -a always,exit -F arch=b64 -S <syscall> for targeted monitoring.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1302","event_name":"AUDIT_PATH","description":"Filename path information - file path context for syscall events. Essential for understanding which files were accessed, modified, or executed during audited operations.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1303","event_name":"AUDIT_IPC","description":"IPC record","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1304","event_name":"AUDIT_SOCKETCALL","description":"sys_socketcall arguments - socket operation details. Detect unauthorized network connections, port binding, and raw socket creation used in packet sniffing.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1305","event_name":"AUDIT_CONFIG_CHANGE","description":"Audit system configuration change - changes to audit rules themselves. Attackers modify audit config to hide activity. Monitor for rule deletions and additions during suspicious timeframes.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1306","event_name":"AUDIT_SOCKADDR","description":"Socket address details (SOCKADDR) - captures remote IP:port for network connections. Essential for correlating process activity with network destinations. Detect C2 communication and unauthorized outbound connections.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1307","event_name":"AUDIT_CWD","description":"Current working directory for syscall events. Provides path context. Processes executing from /tmp, /dev/shm, or /var/tmp are suspicious.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1309","event_name":"AUDIT_EXECVE","description":"EXECVE - captures full command line of executed programs. Essential for detecting malicious commands, encoded payloads (base64), reverse shells, reconnaissance commands (whoami, id, uname -a), and LOLBin-style abuse of system tools.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1311","event_name":"AUDIT_IPC_SET_PERM","description":"IPC new permissions record type","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1312","event_name":"AUDIT_MQ_OPEN","description":"POSIX MQ open record type","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1313","event_name":"AUDIT_MQ_SENDRECV","description":"POSIX MQ send/receive record type","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1314","event_name":"AUDIT_MQ_NOTIFY","description":"POSIX MQ notify record type","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1315","event_name":"AUDIT_MQ_GETSETATTR","description":"POSIX MQ get/set attribute record type","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1316","event_name":"AUDIT_KERNEL_OTHER","description":"For use by 3rd party kernel modules. Custom audit messages from loaded kernel modules. May indicate rootkit activity if source module is unknown.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1317","event_name":"AUDIT_FD_PAIR","description":"audit record for pipe/socketpair","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1318","event_name":"AUDIT_OBJ_PID","description":"ptrace target (OBJ_PID) - identifies the target process of ptrace operations. Ptrace is used for debugging but also for process injection and anti-debugging evasion.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1319","event_name":"AUDIT_TTY","description":"Input on an administrative TTY - captures keystrokes on admin terminals. Essential for detecting unauthorized interactive sessions and recording attacker commands during incidents.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1320","event_name":"AUDIT_EOE","description":"End of multi-record event","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1321","event_name":"AUDIT_BPRM_FCAPS","description":"Information about fcaps increasing perms","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1322","event_name":"AUDIT_CAPSET","description":"CAPSET - records capability changes via sys_capset. Granting CAP_SYS_ADMIN, CAP_NET_RAW, CAP_SYS_PTRACE to unexpected processes indicates privilege escalation.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1323","event_name":"AUDIT_MMAP","description":"MMAP record - memory mapping operations. Detect executable memory mappings from anonymous pages (potential shellcode) and shared library loading from unusual paths.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1324","event_name":"AUDIT_NETFILTER_PKT","description":"Packets traversing netfilter chains","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1325","event_name":"AUDIT_NETFILTER_CFG","description":"Netfilter chain modifications - firewall rule changes. Attackers modify iptables/nftables rules to open access or redirect traffic. Monitor for unexpected rule changes.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1326","event_name":"AUDIT_SECCOMP","description":"SECCOMP event - seccomp-bpf filter violations. Processes violating their sandbox indicate exploitation attempts or misconfigured containers.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1327","event_name":"AUDIT_PROCTITLE","description":"PROCTITLE - full process command line in hex-encoded format. Complements EXECVE for complete execution visibility. Survives command-line argument modifications at runtime.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1328","event_name":"AUDIT_FEATURE_CHANGE","description":"audit log listing feature changes","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1329","event_name":"AUDIT_REPLACE","description":"Replace auditd if this packet unanswerd","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1330","event_name":"AUDIT_KERN_MODULE","description":"Kernel module events - loading/unloading kernel modules. Detect rootkit installation (insmod/modprobe of unknown modules), unauthorized driver loading, and kernel-level persistence.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1331","event_name":"AUDIT_FANOTIFY","description":"Fanotify access decision","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1332","event_name":"AUDIT_TIME_INJOFFSET","description":"Timekeeping offset injected","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1333","event_name":"AUDIT_TIME_ADJNTPVAL","description":"NTP value adjustment","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1334","event_name":"AUDIT_BPF","description":"BPF subsystem events - eBPF program loading. Malicious eBPF programs can intercept network traffic, hide processes, and manipulate system calls. Monitor for non-standard BPF program loads.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1335","event_name":"AUDIT_EVENT_LISTENER","description":"Task joined multicast read socket","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1336","event_name":"AUDIT_URINGOP","description":"io_uring operation","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1337","event_name":"AUDIT_OPENAT2","description":"Record showing openat2 how args","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1338","event_name":"AUDIT_DM_CTRL","description":"Device Mapper target control","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1339","event_name":"AUDIT_DM_EVENT","description":"Device Mapper events","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1400","event_name":"AUDIT_AVC","description":"SELinux AVC denial or grant - mandatory access control decisions. Denials may indicate exploitation attempts hitting MAC boundaries. Grants for unusual contexts need investigation.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1401","event_name":"AUDIT_SELINUX_ERR","description":"Internal SE Linux Errors","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1402","event_name":"AUDIT_AVC_PATH","description":"dentry, vfsmount pair from avc","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1403","event_name":"AUDIT_MAC_POLICY_LOAD","description":"MAC policy file load - SELinux/AppArmor policy changes. Policy reloads may weaken enforcement. Monitor for policy changes outside maintenance windows.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1404","event_name":"AUDIT_MAC_STATUS","description":"MAC status changed - SELinux mode changes between enforcing, permissive, and disabled. Switching to permissive or disabled is a defense evasion technique.","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1405","event_name":"AUDIT_MAC_CONFIG_CHANGE","description":"Changes to booleans","platform":"linux","tags":["audit","linux","kernel"]},{"event_id":"1406","event_name":"AUDIT_MAC_UNLBL_ALLOW","description":"NetLabel: all